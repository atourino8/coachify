# Coachify · variables de entorno (ejemplo)
# Copia este archivo como .env.local y rellena con tus claves reales.
# NUNCA commitees el .env.local — está en el .gitignore.

# Supabase (Fase B)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudinary (Fase C)
PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=

# Resend (emails transaccionales)
RESEND_API_KEY=

# Google OAuth (v1 — citas)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (v1.5)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
